        "emailFormat": "html",
        "html": "=<p>Hi {{ $json.body.data.user_name }},</p>\n<p>It's been <strong>{{ $json.body.data.inactivity_days }} days</strong> since your last practice session. We miss you!</p>\n<p>Your art skills are waiting to be developed further. Even a short 15-minute session can make a big difference.</p>\n<p>Come back and continue your journey. We've saved your progress and have new lessons ready for you.</p>\n<p>See you soon!<br>The Art Buddy Team</p>",
        "options": {}
      },
      "credentials": {
        "smtp": {
          "id": "",
          "name": "SMTP account"
        }
      }
    }
  ],
  "connections": {
    "Engagement Webhook": {
      "main": [
        [
          {
            "node": "Send Engagement Email",
            "type": "main",
            "index": 0
          }
        ]
      ]
