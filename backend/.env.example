# Database
DATABASE_URL=postgresql://art_buddy:password@localhost:5432/art_buddy_db
POSTGRES_USER=art_buddy
POSTGRES_PASSWORD=password
POSTGRES_DB=art_buddy_db

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI/Embeddings - OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
EMBEDDING_MODEL=text-embedding-ada-002
COMPLETION_MODEL=gpt-3.5-turbo

# RAG System Configuration
MAX_CONTEXT_CHUNKS=5
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
TEMPERATURE=0.7
MAX_TOKENS=500

# Vector Database
VECTOR_DB_TYPE=pgvector  # Options: pgvector, pinecone, weaviate

# Knowledge Base Configuration
DEFAULT_KNOWLEDGE_SOURCE=art_fundamentals
ENABLE_KNOWLEDGE_INGESTION=true
AUTO_SETUP_KNOWLEDGE=true

# File Upload Configuration
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=["pdf", "txt", "md", "docx"]

# CORS Configuration (for frontend)
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# n8n Integration
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO